{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .harness/tools/check_active_spec.py"
          },
          {
            "type": "command",
            "command": "python3 .harness/tools/check_completion.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .harness/tools/claude_session_start.py"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git commit -m ' *)"
    ]
  }
}
